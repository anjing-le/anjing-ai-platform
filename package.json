{
  "name": "anjing-ai-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "db:up": "docker compose -f infra/local/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/local/docker-compose.yml down",
    "db:logs": "docker compose -f infra/local/docker-compose.yml logs -f postgres",
    "db:psql": "docker compose -f infra/local/docker-compose.yml exec postgres psql -U anjing -d anjing_ai_platform",
    "db:migrate": "ANJING_DATABASE_URL='postgres://anjing:anjing@localhost:54329/anjing_ai_platform?sslmode=disable' go run ./cmd/migrate-db",
    "db:seed": "ANJING_DATABASE_URL='postgres://anjing:anjing@localhost:54329/anjing_ai_platform?sslmode=disable' go run ./cmd/seed-db",
    "db:prepare": "pnpm db:up && pnpm db:migrate && pnpm db:seed",
    "dev:api": "go run ./cmd/platform-all",
    "dev:api:db": "ANJING_DATABASE_URL='postgres://anjing:anjing@localhost:54329/anjing_ai_platform?sslmode=disable' go run ./cmd/platform-all",
    "smoke:api:db": "node scripts/smoke-postgres-api.mjs",
    "dev:console": "pnpm --filter @anjing-ai-platform/console dev",
    "build:console": "pnpm --filter @anjing-ai-platform/console build",
    "preview:console": "pnpm --filter @anjing-ai-platform/console preview",
    "test:console": "pnpm --filter @anjing-ai-platform/console test",
    "build:go": "go build ./cmd/...",
    "test:go": "go test ./...",
    "image:build": "docker build -t anjing-ai-platform:local .",
    "image:up": "docker compose -f infra/local/docker-compose.image.yml up -d --build",
    "image:down": "docker compose -f infra/local/docker-compose.image.yml down",
    "image:logs": "docker compose -f infra/local/docker-compose.image.yml logs -f platform",
    "verify:workspace": "node scripts/check-workspace.mjs",
    "verify:boundaries": "node scripts/check-service-boundaries.mjs",
    "verify:console-api": "node scripts/check-console-api-client.mjs",
    "verify:commands": "node scripts/check-command-runtime.mjs",
    "verify:compose": "bash scripts/check-compose.sh",
    "verify:docs": "node scripts/check-doc-links.mjs",
    "verify:dockerfile": "node scripts/check-dockerfile-paths.mjs",
    "verify:db-files": "node scripts/check-db-files.mjs",
    "verify:local-dev": "node scripts/check-local-dev-scripts.mjs",
    "verify:smoke-api": "node scripts/smoke-platform-api.mjs",
    "verify:go-build": "pnpm build:go",
    "verify:gofmt": "bash scripts/check-gofmt.sh",
    "verify:govet": "bash scripts/check-govet.sh",
    "verify:openapi-meta": "node scripts/check-openapi-metadata.mjs",
    "verify:openapi": "bash scripts/check-openapi-routes.sh",
    "verify:snapshot": "node scripts/check-platform-snapshot-contract.mjs",
    "verify:role-seeds": "node scripts/check-role-policy-seeds.mjs",
    "verify": "pnpm verify:workspace && pnpm build:console && pnpm test:console && pnpm verify:openapi && pnpm verify:openapi-meta && pnpm verify:boundaries && pnpm verify:console-api && pnpm verify:snapshot && pnpm verify:commands && pnpm verify:role-seeds && pnpm verify:docs && pnpm verify:compose && pnpm verify:dockerfile && pnpm verify:db-files && pnpm verify:local-dev && pnpm verify:smoke-api && pnpm verify:gofmt && pnpm verify:govet && pnpm verify:go-build && go test ./..."
  }
}
