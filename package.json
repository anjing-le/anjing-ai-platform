{
  "name": "anjing-ai-platform",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.10.0",
  "scripts": {
    "db:up": "docker compose -f infra/local/docker-compose.yml up -d",
    "db:down": "docker compose -f infra/local/docker-compose.yml down",
    "db:logs": "docker compose -f infra/local/docker-compose.yml logs -f postgres",
    "db:psql": "docker compose -f infra/local/docker-compose.yml exec postgres psql -U anjing -d anjing_ai_platform",
    "db:migrate": "ANJING_DATABASE_URL='postgres://anjing:anjing@localhost:54329/anjing_ai_platform?sslmode=disable' go run ./cmd/migrate-db",
    "db:seed": "for f in infra/postgres/seeds/*.sql; do docker compose -f infra/local/docker-compose.yml exec -T postgres psql -U anjing -d anjing_ai_platform < \"$f\"; done",
    "dev:console": "pnpm --filter @anjing-ai-platform/console dev",
    "build:console": "pnpm --filter @anjing-ai-platform/console build",
    "preview:console": "pnpm --filter @anjing-ai-platform/console preview",
    "build:go": "go build ./cmd/...",
    "test:go": "go test ./...",
    "image:build": "docker build -t anjing-ai-platform:local .",
    "image:up": "docker compose -f infra/local/docker-compose.image.yml up -d --build",
    "image:down": "docker compose -f infra/local/docker-compose.image.yml down",
    "image:logs": "docker compose -f infra/local/docker-compose.image.yml logs -f platform",
    "verify:boundaries": "node scripts/check-service-boundaries.mjs",
    "verify:compose": "bash scripts/check-compose.sh",
    "verify:docs": "node scripts/check-doc-links.mjs",
    "verify:openapi": "bash scripts/check-openapi-routes.sh",
    "verify": "pnpm build:console && pnpm verify:openapi && pnpm verify:boundaries && pnpm verify:docs && pnpm verify:compose && go test ./..."
  }
}
